{
  "name": "vibeyard",
  "version": "0.2.7",
  "description": "A terminal-centric IDE for AI-powered CLI tools, built on Electron",
  "author": "Eliran Tutia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elirantutia/vibeyard.git"
  },
  "homepage": "https://github.com/elirantutia/vibeyard",
  "bugs": {
    "url": "https://github.com/elirantutia/vibeyard/issues"
  },
  "keywords": [
    "electron",
    "ide",
    "terminal",
    "claude",
    "claude-code",
    "ai",
    "developer-tools"
  ],
  "engines": {
    "node": ">=24"
  },
  "main": "dist/main/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && npm run build:renderer && npm run copy-assets",
    "build:renderer": "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --platform=browser --format=iife --target=es2022 --sourcemap --loader:.ts=ts",
    "copy-assets": "cp src/renderer/index.html dist/renderer/ && cp src/renderer/styles.css dist/renderer/ && cp node_modules/@xterm/xterm/css/xterm.css dist/renderer/xterm.css",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "com.vibeyard.app",
    "productName": "Vibeyard",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "elirantutia",
      "repo": "vibeyard",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0"
  }
}
