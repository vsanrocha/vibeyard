{
  "name": "vibeyard",
  "version": "0.2.19",
  "description": "A terminal-centric IDE for AI-powered CLI tools, built on Electron",
  "author": "Eliran Tutia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elirantutia/vibeyard.git"
  },
  "homepage": "https://github.com/elirantutia/vibeyard",
  "bugs": {
    "url": "https://github.com/elirantutia/vibeyard/issues"
  },
  "bin": {
    "vibeyard": "bin/vibeyard.js"
  },
  "keywords": [
    "electron",
    "ide",
    "terminal",
    "claude",
    "claude-code",
    "ai",
    "developer-tools"
  ],
  "files": [
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/main/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && npm run build:renderer && npm run copy-assets",
    "build:renderer": "esbuild src/renderer/index.ts --bundle --outfile=dist/renderer/index.js --platform=browser --format=iife --target=es2022 --sourcemap --loader:.ts=ts",
    "copy-assets": "cp src/renderer/index.html dist/renderer/ && cp src/renderer/styles.css dist/renderer/ && rm -rf dist/renderer/styles && cp -r src/renderer/styles dist/renderer/styles && cp node_modules/@xterm/xterm/css/xterm.css dist/renderer/xterm.css && cp build/icon.png dist/renderer/icon.png && cp CHANGELOG.md dist/renderer/",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "postinstall": "test -f node_modules/electron-builder/package.json && electron-builder install-app-deps || true",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "com.vibeyard.app",
    "productName": "Vibeyard",
    "icon": "build/icon.png",
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "elirantutia",
      "repo": "vibeyard",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "picomatch": "^4.0.3"
  }
}
